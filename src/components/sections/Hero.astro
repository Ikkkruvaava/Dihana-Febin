---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import HeroIlust from "../../assets/pics/hero.svg";
---

<Section id="home">
<div class="relative flex flex-col-reverse items-center md:flex-row" id="hero">
    <div class="row items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <div class="text-left space-y-3">
            <h1 class="text-4xl font-medium leading-none md:text-6xl text-center md:text-left">Hi, I'm Dihana — <br> A <span class="greenhead">Digital Marketer</span> <br> Who Makes Brands <br> Actually Connect.</h1>
            <p class="mt-6 mb-8 text-lg font-normal leading-7 sm:mb-12 text-center md:text-left md:pr-12">Strategy. Creativity. Results That Grow. I blend SEO, Meta Ads, content, and design to build brand presence that people actually notice.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
                <a href="#work" class="px-8 py-5 bg-zinc-900 hover:bg-white rounded-2xl text-center text-white hover:text-black border text-xl font-normal leading-7">View My Work</a>
                <a href="#contact" class="px-8 py-5 bg-transparent hover:bg-zinc-900 rounded-2xl text-center text-black hover:text-white border border-zinc-900 text-xl font-normal leading-7">Let's Connect</a>
            </div>
        </div>
    </div>
    <div class="flex items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <Image src={HeroIlust} alt="Digital Marketing Illustration" loading="eager" />
    </div>
</div>
</Section>