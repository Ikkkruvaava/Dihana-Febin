---
import SectionTitle from "../ui/SectionTitle.astro";
import Section from "./Section.astro";

const industrySkills = [
  "Digital Marketing",
  "Social Media Marketing",
  "SEO",
  "Content Strategy",
  "Meta Ads",
  "Google Ads",
  "Brand Strategy",
];

const tools = [
  "Adobe Photoshop",
  "Adobe Illustrator",
  "Meta Business Suite",
  "Google Analytics",
  "Canva",
  "Content Calendar Management",
];
---

<Section id="skills">
  <div class="mt-[140px] mb-5">
    <SectionTitle
      sectionTitle="Skills & Tools"
      description="The tools and techniques I use to build brands."
    />
    <div class="space-y-8">
      <!-- Industry Knowledge -->
      <div>
        <h3 class="text-lg font-medium mb-4 text-dark/70">Industry Knowledge</h3>
        <div class="flex flex-wrap gap-3">
          {
            industrySkills.map((skill) => (
              <span class="px-6 py-3 rounded-full text-base font-medium bg-dark text-green border border-dark hover:bg-green hover:text-dark transition-all duration-300 cursor-default shadow-[0px_3px_0px_#191a23]">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
      <!-- Tools & Technologies -->
      <div>
        <h3 class="text-lg font-medium mb-4 text-dark/70">Tools & Technologies</h3>
        <div class="flex flex-wrap gap-3">
          {
            tools.map((tool) => (
              <span class="px-6 py-3 rounded-full text-base font-medium bg-green text-dark border border-dark hover:bg-dark hover:text-green transition-all duration-300 cursor-default shadow-[0px_3px_0px_#191a23]">
                {tool}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Section>
