---
import SectionTitle from "../ui/SectionTitle.astro";
import Section from "./Section.astro";

const stats = [
  { value: "9+", label: "Months", sub: "Professional Experience" },
  { value: "2", label: "Certifications", sub: "Digital Marketing & Graphic Design" },
  { value: "500+", label: "Connections", sub: "LinkedIn Network" },
];
---

<Section id="about">
  <div class="mt-[140px]">
    <SectionTitle sectionTitle="About Me" description="Get to know the person behind the brand." />
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
      <!-- Left Column: Photo + Name -->
      <div class="flex flex-col items-center lg:items-start gap-6">
        <div class="w-64 h-64 rounded-full bg-gradient-to-br from-green to-dark flex items-center justify-center border-4 border-green overflow-hidden">
          <img src="/Dihana1.webp" alt="Dihana Febin" class="w-full h-full object-cover" />
        </div>
        <div class="text-center lg:text-left">
          <h3 class="text-2xl font-medium">Dihana Febin</h3>
          <p class="text-lg text-dark/70">Digital Marketer at Iberr Technologies LLP</p>
          <p class="text-sm text-dark/50 mt-1">Kerala, India</p>
        </div>
        <a
          href="https://www.linkedin.com/in/dihanafebin/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-flex items-center gap-2"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          Connect on LinkedIn
        </a>
      </div>

      <!-- Right Column: Bio + Stats -->
      <div class="flex flex-col gap-8">
        <div class="space-y-4 text-base leading-relaxed">
          <p>
            I'm Dihana Febin, a Digital Marketer based in Kerala, India,
            currently working at Iberr Technologies LLP.
          </p>
          <p>
            Digital marketing is how I think — not just what I do.
            Every day, I'm building brand presence through content,
            campaigns, and creative strategy that actually connects with people.
          </p>
          <p>
            I work with Photoshop, Illustrator, SEO, and Meta Ads,
            blending creativity with data to make marketing that cuts through
            the noise. I'm a B.Com graduate from the University of Calicut,
            and I'm always learning, always creating.
          </p>
          <p class="font-medium">
            My mission? Putting the right message in front of the right people.
          </p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {
            stats.map((stat) => (
              <div class="bg-gray rounded-2xl p-5 text-center border border-dark/10 shadow-[0px_3px_0px_#191a23]">
                <div class="text-2xl md:text-3xl font-medium text-dark">
                  {stat.value}
                </div>
                <div class="text-sm font-medium text-dark mt-1">{stat.label}</div>
                <div class="text-xs text-dark/50 mt-1">{stat.sub}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Section>
